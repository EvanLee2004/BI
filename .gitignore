__pycache__/
*.pyc
.DS_Store
.~*
# Python 虚拟环境（本机/部署机各自建，不进库）
.venv/
venv/
# 管理员密码哈希 + 会话签名密钥（绝不进库）
数据/管理员密钥.json
# 智云连接配置（内网IP/账号GUID/登录cookie）——绝不进库；兜底挡掉 数据/ 下一切 json
数据/智云配置.json
# 机器本地配置覆盖（收单台账共享盘路径/更新时间/备份天数等·管理端设置页写这里）——每台机不同、含内网路径，绝不进库；
# 有它 config.json 才永不被程序改脏→git 工作区干净→一键更新可用（见 loaders.load_config / F-01 修复）
数据/本地配置.json
数据/*.json

# 真实经营数据永不进库（“真实数据不出本机”）。
# 部署时把真实数据放进 数据/ 覆盖同名文件即可，git 不会带走它。
数据/*.xlsx
数据/*.csv
# SQLite 库含真实金额/客户名——绝不进库；备份/快照/原始下载同理（数据/ 目录内容只留 README 进 git）
数据/*.db
数据/*.db-journal
数据/*.db-wal
数据/*.db-shm
# 金额分迁移前自动备份（SCHEMA 升级）
数据/*.db.bak-fen-*
数据/备份/
数据/快照存档/
数据/1_原始下载/
# 兜底：曾出现过“数据_样例/”实为真实数据副本、泄露到公开库约1天（2026-07-06）。
# 该文件夹已移出程序、真实数据只留本机备份；此处防它被重新创建后再次误进库。
数据_样例/
# docs/参考 是内部映射参考(部门→BU 等)，公开发布时按 progress 一并排除。
docs/参考/

# 生成物：每次 run.py 都会重新生成，无需进库（也含真实数字，别外泄）
output/
data/驾驶舱数据.json
data/*.json
# 浏览器调试工具落盘产物（页面快照含真实人名/数字）——绝不进库
.playwright-cli/

# Claude Code 本地工具配置（不进公开仓库）
.claude/

# 一键更新回滚点标记（本机运行态：apply_update 写更新前 commit，看门狗据此失败回滚）
.update_rollback

# 重构 golden 用临时假数据目录（可重建）
_golden_data/
golden/_run_verify_raw.log
.coverage

# 任务书46：Vue 依赖不进 git（dist 进 git）
frontend/node_modules/
