{
  "_comment": "经营驾驶舱 v6 业务口径唯一配置源。切换测试/正式数据只改 data_dir 与 period_pin 两处，代码不动。",

  "data_dir": "数据",
  "_data_dir_note": "产品数据目录——6个数据源固定放这里(文件名见files)。每月用新导出/新填的数据覆盖同名文件即可，程序永远读这个目录。当前放的是2026年测试数据(当正式数据对待)，来了真数据直接覆盖。",

  "period_pin": null,
  "_period_pin_note": "null=用系统当天（正式版/2026多月测试数据都用这个，年份自动跟当前年走，2027/2028照常）。要复现历史某月可填 {year,month}。",

  "files": {
    "project_detail_stem": "项目明细",
    "ledger": "收单台账.xlsx",
    "orders": "下单.xlsx",
    "receipts": "回款记录.xlsx",
    "inhouse": "内部译员.xlsx",
    "manual": "手填与调整.xlsx"
  },

  "tax": {
    "vat_rate": 0.06,
    "surtax_rate": 0.12,
    "_note": "收入(不含税)=交付额/(1+vat_rate)；附加税费=收入(不含税)×vat_rate×surtax_rate（陆总：收入×6%×12%）"
  },

  "columns": {
    "project_delivery_date": "整单交付日期",
    "project_revenue": "交付额/本币",
    "project_cost": "项目成本/本币",
    "project_line": "业务线",
    "order_amount": "下单预估额/本币",
    "order_date": "下单日期",
    "receipt_amount": "到账金额/本币",
    "receipt_date": "到账日期",
    "inhouse_amount": "本币结算/Amount",
    "inhouse_date": "任务提交日期/Submission Time",
    "inhouse_type": "译员类型",
    "_inhouse_type_note": "只取 译员类型 含 IN-HOUSE 的行（内部专职译员）作系统内部译员成本"
  },

  "inhouse_keyword": "IN-HOUSE",

  "expense_categories_included": ["市场费用", "管理费用", "固定运营费用", "技术服务费", "财务费用"],
  "expense_categories_excluded": ["成本", "工资", "非利润表"],
  "unclassified_label_expense": "未分类",
  "unclassified_label_bu": "未分类BU",
  "unclassified_label_fine_type": "未标注明细类型",

  "manual_items": [
    { "name": "营销人力成本",   "role": "营销费用", "default": "prev" },
    { "name": "管理人力成本",   "role": "管理费用", "default": "prev" },
    { "name": "研发人力成本",   "role": "研发费用", "default": "prev" },
    { "name": "财务费用补充",   "role": "财务费用", "default": "prev" },
    { "name": "PM人力成本",     "role": "生产成本", "default": "prev" },
    { "name": "VM人力成本",     "role": "生产成本", "default": "prev" },
    { "name": "实际内部译员成本", "role": "生产成本", "default": "prev" },
    { "name": "税费损失",       "role": "生产成本", "default": "prev" },
    { "name": "技术流量成本",   "role": "生产成本", "default": "prev" },
    { "name": "其他（生产成本）", "role": "生产成本", "default": "prev" },
    { "name": "其他损益",       "role": "利润表",   "default": "zero" }
  ],
  "_manual_note": "系统导不出、财务每月手填；default=prev 不填默认上月，default=zero 不填默认0。归属见 role。",

  "output_dir": "output",
  "output_html": "经营驾驶舱.html",
  "output_json": "data/驾驶舱数据.json",

